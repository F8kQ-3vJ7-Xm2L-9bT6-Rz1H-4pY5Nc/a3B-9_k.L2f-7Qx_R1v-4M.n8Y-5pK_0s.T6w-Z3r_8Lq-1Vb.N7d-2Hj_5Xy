DisableAllMainFeatures()

end,

})



MainTab:CreateDivider()



-- [[ 3. MAIN TARGETING SYSTEMS ]] --

UI_Toggles.FollowToggle = MainTab:CreateToggle({

Name = "Follow Target(s)",

CurrentValue = false,

Flag = "FollowToggle",

Callback = function(Value)

_G.Following = Value

sendNotify("Follow System", Value and "Started chasing" or "Stopped chasing")



    if connections.Follow then connections.Follow:Disconnect() end

    if connections.HealthMonitor then connections.HealthMonitor:Disconnect() end

   

    if Value then

        _G.TeleportAttempts = 0

        _G.TPFailedNotified = false

       

        local function setupHealthMonitor(char)

            local hum = char:WaitForChild("Humanoid", 5)

            if hum then

                previousHealth = hum.Health

                connections.HealthMonitor = hum.HealthChanged:Connect(function(newHealth)

                    if newHealth < previousHealth and _G.RevengeMode and not _G.RevengeActive then

                        local nearest = findNearestHumanoid()

                        if nearest then

                            local isCurrentTarget = false

                            if #_G.TargetList > 0 then

                                local currentTargetId = _G.TargetList[_G.CurrentTargetIndex]

                                local targetPlr = Players:GetPlayerByUserId(currentTargetId)

                                if targetPlr and targetPlr.Character and targetPlr.Character:FindFirstChild("HumanoidRootPart") == nearest then

                                    isCurrentTarget = true

                                end

                            end

                           

                            if not isCurrentTarget then

                                _G.RevengeTarget = nearest

                                _G.RevengeActive = true

                                _G.RevengeStartTime = tick()

                                _G.TeleportAttempts = 0

                                sendNotify("Revenge Triggered!", "Attacking nearest entity!")

                            end

                        end

                    end

                    previousHealth = newHealth

                end)

            end

        end

        if LocalPlayer.Character then setupHealthMonitor(LocalPlayer.Character) end

        LocalPlayer.CharacterAdded:Connect(setupHealthMonitor)



        connections.Follow = RunService.Heartbeat:Connect(function()

            if not _G.Following then return end

           

            local myChar = LocalPlayer.Character

            local myHum = myChar and myChar:FindFirstChild("Humanoid")

            local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

           

            if myChar ~= _G.LastChar then

                _G.LastChar = myChar

                _G.SpawnTime = tick()

                _G.FlingStrikes = 0

                _G.TeleportAttempts = 0

            end

           

            if not myHum or myHum.Health <= 0 then

                if not _G.WasDead then _G.WasDead = true end

                return

            elseif _G.WasDead then

                _G.WasDead = false

                targetStartTime = tick()

            end

           

            -- REVENGE LOGIC

            if _G.RevengeActive and _G.RevengeTarget then

                local tHum = _G.RevengeTarget.Parent and _G.RevengeTarget.Parent:FindFirstChild("Humanoid")

                local timePassed = tick() - _G.RevengeStartTime

                local dist = (myRoot and _G.RevengeTarget) and (_G.RevengeTarget.Position - myRoot.Position).Magnitude or 0

               

                if not tHum or tHum.Health <= 0 or _G.RevengeTarget.Velocity.Magnitude > 250 or timePassed > 10 then

                    _G.RevengeActive = false

                    _G.RevengeTarget = nil

                    targetStartTime = tick()

                    _G.TeleportAttempts = 0

                    return

                else

                    if _G.DistanceTeleport and dist > 50 then

                        local now = tick()

                        if _G.TeleportAttempts == 0 then

                            myRoot.CFrame = _G.RevengeTarget.CFrame * CFrame.new(0, 0, 3)

                            breakVelocity()

                            _G.TeleportAttempts = 1

                            _G.TeleportTime = now

                        elseif _G.TeleportAttempts == 1 and now - _G.TeleportTime > 2 then

                            myRoot.CFrame = _G.RevengeTarget.CFrame * CFrame.new(0, 0, 3)

                            breakVelocity()

                            _G.TeleportAttempts = 2

                            _G.TeleportTime = now

                        end

                    end

                    myHum:MoveTo(_G.RevengeTarget.Position)

                    return

                end

            end



            if #_G.TargetList == 0 then return end

            if _G.CurrentTargetIndex > #_G.TargetList then _G.CurrentTargetIndex = 1 end

           

            local currentTargetId = _G.TargetList[_G.CurrentTargetIndex]

            local targetPlr = Players:GetPlayerByUserId(currentTargetId)

            if not targetPlr then advanceTarget("offline", currentTargetId) return end

           

            local targetRoot = targetPlr.Character and targetPlr.Character:FindFirstChild("HumanoidRootPart")

            if targetPlr.Character and targetRoot then

                local targetHum = targetPlr.Character:FindFirstChild("Humanoid")

                if targetHum and targetHum.Health > 0 and myHum and myHum.Health > 0 then

                   

                    local dist = (targetRoot.Position - myRoot.Position).Magnitude

                   

                    if targetRoot.Velocity.Magnitude > 250 then advanceTarget("flung", currentTargetId) return end

                   

                    -- 2-STRIKE TELEPORT SYSTEM

                    if _G.DistanceTeleport then

                        if dist > 50 then

                            local now = tick()

                            if _G.TeleportAttempts == 0 then

                                myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 3)

                                breakVelocity()

                                _G.TeleportAttempts = 1

                                _G.TeleportTime = now

                                return

                            elseif _G.TeleportAttempts == 1 and now - _G.TeleportTime > 2 then

                                myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 3)

                                breakVelocity()

                                _G.TeleportAttempts = 2

                                _G.TeleportTime = now

                                return

                            elseif _G.TeleportAttempts == 2 and now - _G.TeleportTime > 2 then

                                if #_G.TargetList == 1 then

                                    if now - _G.TeleportTime > _G.SoloTPInterval then

                                        myRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 3)

                                        breakVelocity()

                                        _G.TeleportTime = now

                                    end

                                else

                                    if not _G.TPFailedNotified then

                                        sendNotify("Teleport Failed", "Target evading. Using Patience Timer.")

                                        _G.TPFailedNotified = true

                                    end

                                    if not _G.SmartTargeting then

                                        advanceTarget("timeout", currentTargetId)

                                        return

                                    end

                                end

                            end

                        else

                            if dist <= 50 then

                                _G.TeleportAttempts = 0

                                _G.TPFailedNotified = false

                            end

                        end

                    end

                   

                    -- AUTO JUMP LOGIC

                    if _G.AutoJump and dist > 5 then

                        if myRoot.Velocity.Magnitude < 2 then

                            _G.StuckTicks = _G.StuckTicks + 1

                            if _G.StuckTicks > 10 then

                                if _G.SyncJump then

                                    _G.NeedsJump = true

                                else

                                    myHum.Jump = true

                                end

                                _G.StuckTicks = 0

                            end

                        else

                            _G.StuckTicks = 0

                        end

                    end



                    myHum:MoveTo(targetRoot.Position)

                   

                else advanceTarget("dead", currentTargetId) end

            else advanceTarget("dead", currentTargetId) end

        end)

    end

end,

})



