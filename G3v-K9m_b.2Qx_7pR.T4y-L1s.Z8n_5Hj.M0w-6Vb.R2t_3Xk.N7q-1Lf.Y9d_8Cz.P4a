local ExtraTab = Window:CreateTab("Extra Scripts", 4483362458)

local CreditsTab = Window:CreateTab("Credits", 4483362458)



-- [[ STATE VARIABLES ]] --

_G.TargetList = {}

_G.CurrentTargetIndex = 1

_G.Following = false



_G.DistanceTeleport = false

_G.TeleportAttempts = 0

_G.TeleportTime = 0

_G.TPFailedNotified = false

_G.SoloTPInterval = MySettings.SoloTP



_G.SmartTargeting = false

_G.AutoAddPlayers = false

_G.LoopSpeedValue = MySettings.WalkSpeed



_G.SelectedKey = MySettings.Key

_G.SecondaryKey = MySettings.SecKey

_G.SecondaryPulse = false

_G.PulseDuration = MySettings.Pulse

_G.PulseKey = false



_G.FlingEnabled = false

_G.LoopTPTool = false

_G.LoopServerHop = false

_G.WasDead = false

_G.LastChar = nil

_G.SpawnTime = tick()

_G.FlingStrikes = 0

_G.LastAdvance = 0



-- V28 Management Tables

_G.SkippedUntilRespawn = {}

_G.BlacklistedTargets = {}



-- Revenge Variables

_G.RevengeMode = false

_G.RevengeActive = false

_G.RevengeTarget = nil

_G.RevengeStartTime = 0

local previousHealth = 100



-- Auto-Jump Variables

_G.AutoJump = false

_G.SyncJump = false

_G.NeedsJump = false

_G.StuckTicks = 0



-- UI Elements Storage

local UI_Toggles = {}



local connections = {}

local HumanModCons = {}

local targetStartTime = tick()

local lastTargetId = nil



-- [[ HELPER FUNCTIONS ]] --

local function breakVelocity()

local char = LocalPlayer.Character

if char then

for _, v in ipairs(char:GetDescendants()) do

if v:IsA("BasePart") then

v.Velocity = Vector3.new(0, 0, 0)

v.RotVelocity = Vector3.new(0, 0, 0)

end

end

end

end



local function sendNotify(title, text)

pcall(function() StarterGui:SetCore("SendNotification", { Title = title, Text = text, Duration = 3 }) end)

end



local VoidLabel = CreditsTab:CreateLabel("Total Players Voided: " .. tostring(MySettings.TotalVoids))



local function getPlayerNames()

local names = {}

for _, plr in ipairs(Players:GetPlayers()) do

if plr ~= LocalPlayer then table.insert(names, plr.DisplayName .. " (@" .. plr.Name .. ")") end

end

return names

end



local function getUserIdFromFormat(formattedString)

local username = string.match(formattedString, "@(.-)%)$")

if username then

local plr = Players:FindFirstChild(username)

if plr then return plr.UserId end

end

return nil

end



local function getFormattedNameFromId(id)

if not id then return "Unknown" end

local plr = Players:GetPlayerByUserId(id)

if plr then return plr.DisplayName .. " (@" .. plr.Name .. ")" end

return "Offline Player"

end



local function findNearestHumanoid()

local myChar = LocalPlayer.Character

local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

if not myRoot then return nil end



local nearest = nil

local minDist = 1000

for _, obj in ipairs(workspace:GetDescendants()) do

    if obj:IsA("Humanoid") and obj.Health > 0 and obj.Parent ~= myChar then

        local root = obj.Parent:FindFirstChild("HumanoidRootPart")

        if root then

            local dist = (root.Position - myRoot.Position).Magnitude

            if dist < minDist then

                minDist = dist

                nearest = root

            end

        end

    end

end

return nearest

end



local function getNextValidTargetIndex(startIndex)

local myChar = LocalPlayer.Character

local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")

if not myRoot then return startIndex + 1 end



local checkCount = 0

local currentIndex = startIndex + 1



while checkCount < #_G.TargetList do

    if currentIndex > #_G.TargetList then currentIndex = 1 end

    local id = _G.TargetList[currentIndex]

    local targetPlr = Players:GetPlayerByUserId(id)

   

    if not _G.SkippedUntilRespawn[id] then

        if targetPlr and targetPlr.Character then

            local tRoot = targetPlr.Character:FindFirstChild("HumanoidRootPart")

            local tHum = targetPlr.Character:FindFirstChild("Humanoid")

            if tRoot and tHum and tHum.Health > 0 then

                if tRoot.Velocity.Magnitude < 250 then return currentIndex end

            end

        end

    end

    currentIndex = currentIndex + 1

    checkCount = checkCount + 1

end

return startIndex + 1

end



local function advanceTarget(reason, oldId)

if tick() - _G.LastAdvance < 1 and reason ~= "skipped" and reason ~= "removed" then return end

_G.LastAdvance = tick()



if reason == "flung" or reason == "glitch" or reason == "dead" then

    MySettings.TotalVoids = MySettings.TotalVoids + 1

    VoidLabel:Set("Total Players Voided: " .. tostring(MySettings.TotalVoids))

    SaveToFile()

end



local oldName = getFormattedNameFromId(oldId)

if reason == "offline" or reason == "removed" then

    for i, v in ipairs(_G.TargetList) do

        if v == oldId then table.remove(_G.TargetList, i) break end

    end

    if #_G.TargetList == 0 then

        sendNotify("Target List Empty", oldName .. " was removed. Hitlist is empty!")

        _G.Following = false

        if UI_Toggles.FollowToggle then UI_Toggles.FollowToggle:Set(false) end

        return

    end

end



if #_G.TargetList <= 1 then

    targetStartTime = tick()

    _G.TeleportAttempts = 0

    _G.TPFailedNotified = false

    return

end



_G.CurrentTargetIndex = getNextValidTargetIndex(_G.CurrentTargetIndex)

local newId = _G.TargetList[_G.CurrentTargetIndex]



if newId == oldId then

    targetStartTime = tick()

    _G.TeleportAttempts = 0

    _G.TPFailedNotified = false

    return

end



local newName = getFormattedNameFromId(newId)



if reason == "flung" then sendNotify("Detected Flung!", oldName .. " flung! Next: " .. newName)

elseif reason == "glitch" then sendNotify("Sent to Void!", oldName .. " hit glitch zone! Next: " .. newName)

elseif reason == "timeout" then sendNotify("Timeout", oldName .. " evaded. Next: " .. newName)

elseif reason == "dead" then sendNotify("Target Dead", oldName .. " died. Next: " .. newName)

elseif reason == "offline" then sendNotify("Target Left", oldName .. " left. Next: " .. newName)

elseif reason == "skipped" then sendNotify("Skipped", oldName .. " skipped until respawn. Next: " .. newName)

elseif reason == "removed" then sendNotify("Removed", oldName .. " permanently blacklisted. Next: " .. newName)

end



targetStartTime = tick()

lastTargetId = newId

_G.TeleportAttempts = 0

_G.TPFailedNotified = false

end



-- UNIVERSAL INPUT PARSER

local function ParseInput(str)

if not str then return nil end

local s = string.lower(str)

if s == "m1" or s == "mouse1" or s == "click" then return {Type = "Mouse", Btn = 0} end

if s == "m2" or s == "mouse2" or s == "rightclick" then return {Type = "Mouse", Btn = 1} end

if s == "m3" or s == "mouse3" or s == "middleclick" then return {Type = "Mouse", Btn = 2} end



local success, code = pcall(function() return Enum.KeyCode[string.upper(str)] end)

if success then return {Type = "Key", Code = code} end



success, code = pcall(function() return Enum.KeyCode[str:gsub("^%l", string.upper)] end)

if success then return {Type = "Key", Code = code} end



return nil

end



local function FireInput(inputObj, isDown)

if not inputObj then return end

if inputObj.Type == "Mouse" then

VIM:SendMouseButtonEvent(0, 0, inputObj.Btn, isDown, game, 0)

elseif inputObj.Type == "Key" then

VIM:SendKeyEvent(isDown, inputObj.Code, false, game)

end

end



-- RESPAWN TRACKER

local function monitorRespawn(plr)

plr.CharacterAdded:Connect(function()

if _G.SkippedUntilRespawn[plr.UserId] then

_G.SkippedUntilRespawn[plr.UserId] = nil

sendNotify("Target Respawned", plr.Name .. " is targetable again.")

end

end)

end

for _, plr in ipairs(Players:GetPlayers()) do monitorRespawn(plr) end



-- [[ 1. TARGET MANAGEMENT SYSTEM ]] --

local FollowDropdown = MainTab:CreateDropdown({

Name = "Select Targets (Hitlist)",

Options = getPlayerNames(),

CurrentOption = {},

MultipleOptions = true,

Flag = "FollowDropdown",

Callback = function(Options)

_G.TargetList = {}

for _, opt in ipairs(Options) do

local id = getUserIdFromFormat(opt)

if id then

table.insert(_G.TargetList, id)

_G.BlacklistedTargets[id] = nil

end

end

_G.CurrentTargetIndex = 1

_G.TeleportAttempts = 0

_G.TPFailedNotified = false

end,

})



Players.PlayerAdded:Connect(function(plr)

monitorRespawn(plr)

FollowDropdown:Refresh(getPlayerNames(), true)

if _G.AutoAddPlayers and not _G.BlacklistedTargets[plr.UserId] then

table.insert(_G.TargetList, plr.UserId)

local currentOpts = FollowDropdown.CurrentOption

table.insert(currentOpts, plr.DisplayName .. " (@" .. plr.Name .. ")")

FollowDropdown:Set(currentOpts)

sendNotify("Hitlist Update", plr.Name .. " auto-added to targets!")

end

end)

Players.PlayerRemoving:Connect(function() FollowDropdown:Refresh(getPlayerNames(), true) end)



