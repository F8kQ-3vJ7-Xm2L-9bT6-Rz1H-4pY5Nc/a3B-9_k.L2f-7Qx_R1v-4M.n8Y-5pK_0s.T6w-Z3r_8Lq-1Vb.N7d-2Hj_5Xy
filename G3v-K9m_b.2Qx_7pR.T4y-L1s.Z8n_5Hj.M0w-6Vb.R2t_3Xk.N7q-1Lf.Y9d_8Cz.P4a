})



MainTab:CreateInput({

Name = "Secondary Gap Key (Saved: " .. MySettings.SecKey .. ")",

PlaceholderText = "M2, Shift, R...",

RemoveTextAfterFocusLost = false,

Callback = function(Text)

_G.SecondaryKey = Text

MySettings.SecKey = Text

SaveToFile()

end,

})



MainTab:CreateToggle({

Name = "Enable Secondary Key in Gap",

CurrentValue = false,

Flag = "SecPulseToggle",

Callback = function(Value)

_G.SecondaryPulse = Value

end,

})



UI_Toggles.PulseKeyToggle = MainTab:CreateToggle({

Name = "Start Pulse Engine",

CurrentValue = false,

Flag = "PulseKeyToggle",

Callback = function(Value)

_G.PulseKey = Value

if Value then

task.spawn(function()

while _G.PulseKey do

local mainK = ParseInput(_G.SelectedKey)

local secK = ParseInput(_G.SecondaryKey)



                if mainK then FireInput(mainK, true) end

                task.wait(_G.PulseDuration)

                if mainK then FireInput(mainK, false) end

               

                if _G.SecondaryPulse and secK then

                    FireInput(secK, true)

                    task.wait()

                    FireInput(secK, false)

                else

                    task.wait()

                end

               

                if _G.SyncJump and _G.NeedsJump then

                    local myHum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid")

                    if myHum then myHum.Jump = true end

                    _G.NeedsJump = false

                end

            end

        end)

    end

end,

})



MainTab:CreateDivider()



-- [[ 4. TOUCH FLING SYSTEM ]] --

UI_Toggles.TouchFlingToggle = MainTab:CreateToggle({

Name = "Fling On Touch",

CurrentValue = false,

Flag = "TouchFlingToggle",

Callback = function(Value)

_G.FlingEnabled = Value

if Value then

task.spawn(function()

local movel = 0.1

while _G.FlingEnabled do

RunService.Heartbeat:Wait()

local char = LocalPlayer.Character

local hrp = char and char:FindFirstChild("HumanoidRootPart")

if hrp then

local vel = hrp.Velocity

hrp.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)

RunService.RenderStepped:Wait()

if char and hrp and hrp.Parent then hrp.Velocity = vel end

RunService.Stepped:Wait()

if char and hrp and hrp.Parent then

hrp.Velocity = vel + Vector3.new(0, movel, 0)

movel = -movel

end

end

end

end)

end

end,

})



MainTab:CreateDivider()



-- [[ 5. TELEPORT TOOL ]] --

local TPToolName = "Teleport Tool"

UI_Toggles.TPToolToggle = MainTab:CreateToggle({

Name = "Loop Give Teleport Tool",

CurrentValue = false,

Flag = "TPToolToggle",

Callback = function(Value)

_G.LoopTPTool = Value

if Value then

task.spawn(function()

while _G.LoopTPTool do

local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")

local char = LocalPlayer.Character

if _G.LoopTPTool and backpack and char then

if not backpack:FindFirstChild("Teleport Tool") and not char:FindFirstChild("Teleport Tool") then

local TpTool = Instance.new("Tool")

TpTool.Name = "Teleport Tool"

TpTool.RequiresHandle = false

TpTool.Parent = backpack

TpTool.Activated:Connect(function()

local root = char:FindFirstChild("HumanoidRootPart")

if root and Mouse.Hit then

root.CFrame = CFrame.new(Mouse.Hit.X, Mouse.Hit.Y + 3, Mouse.Hit.Z, select(4, root.CFrame:components()))

root.Velocity = Vector3.new(0,0,0)

root.RotVelocity = Vector3.new(0,0,0)

end

end)

end

end

task.wait(0.5)

end

end)

else

local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")

local char = LocalPlayer.Character

if backpack and backpack:FindFirstChild("Teleport Tool") then backpack["Teleport Tool"]:Destroy() end

if char and char:FindFirstChild("Teleport Tool") then char["Teleport Tool"]:Destroy() end

end

end,

})



-- [[ 6. SHOW INVENTORY LOOP ]] --

MainTab:CreateToggle({

Name = "Force Show Native Roblox Inventory",

CurrentValue = false,

Flag = "ShowInvToggle",

Callback = function(Value)

if Value then

pcall(function() wasInventoryEnabled = StarterGui:GetCoreGuiEnabled(Enum.CoreGuiType.Backpack) end)

connections.InventoryLoop = RunService.RenderStepped:Connect(function()

pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true) end)

end)

else

if connections.InventoryLoop then connections.InventoryLoop:Disconnect() end

pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, wasInventoryEnabled) end)

end

end,

})



-- [[ 7. EXTRA SERVER UTILITIES ]] --

local function performServerHopCommand()

local servers = {}

local success, req = pcall(function() return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true") end)

if success and req then

local body = HttpService:JSONDecode(req)

if body and body.data then

for _, v in next, body.data do

if type(v) == "table" and tonumber(v.playing) and tonumber(v.maxPlayers) and v.playing < v.maxPlayers and v.id ~= game.JobId then

table.insert(servers, 1, v.id)

end

end

end

end

if #servers > 0 then TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], LocalPlayer) end

end



ExtraTab:CreateButton({ Name = "Server Hop", Callback = function() task.wait(1) performServerHopCommand() end })

ExtraTab:CreateToggle({

Name = "Loop Server Hop (MAX SPEED)",

CurrentValue = false,

Flag = "LoopHopToggle",

Callback = function(Value)

_G.LoopServerHop = Value

if Value then task.spawn(function() while _G.LoopServerHop do performServerHopCommand() task.wait() end end) end

end,

})

ExtraTab:CreateButton({

Name = "Rejoin Server",

Callback = function()

task.wait(1)

if #Players:GetPlayers() <= 1 then LocalPlayer:Kick("\nRejoining...") task.wait() TeleportService:Teleport(game.PlaceId, LocalPlayer)

else TeleportService:TeleportToPlaceInstance(game.PlaceId, game.JobId, LocalPlayer) end

end,

})

ExtraTab:CreateDivider()

ExtraTab:CreateButton({ Name = "Execute Infinite Yield", Callback = function() loadstring(game:HttpGet('https://raw.githubusercontent.com/EdgeIY/infiniteyield/master/source'))() end })



