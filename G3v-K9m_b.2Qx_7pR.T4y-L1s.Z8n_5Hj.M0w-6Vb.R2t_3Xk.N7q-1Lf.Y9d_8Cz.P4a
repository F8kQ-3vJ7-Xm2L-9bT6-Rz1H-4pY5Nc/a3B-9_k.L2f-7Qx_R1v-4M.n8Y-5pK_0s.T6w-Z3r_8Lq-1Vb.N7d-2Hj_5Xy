-- [[ 2. MASTER KILL SWITCH ]] --

local function DisableAllMainFeatures()

if UI_Toggles.FollowToggle then UI_Toggles.FollowToggle:Set(false) end

if UI_Toggles.DistTPToggle then UI_Toggles.DistTPToggle:Set(false) end

if UI_Toggles.RevengeToggle then UI_Toggles.RevengeToggle:Set(false) end

if UI_Toggles.JumpToggle then UI_Toggles.JumpToggle:Set(false) end

if UI_Toggles.SmartTargetToggle then UI_Toggles.SmartTargetToggle:Set(false) end

if UI_Toggles.LoopWSToggle then UI_Toggles.LoopWSToggle:Set(false) end

if UI_Toggles.PulseKeyToggle then UI_Toggles.PulseKeyToggle:Set(false) end

if UI_Toggles.TouchFlingToggle then UI_Toggles.TouchFlingToggle:Set(false) end

if UI_Toggles.TPToolToggle then UI_Toggles.TPToolToggle:Set(false) end

sendNotify("Panic Switch", "All main features disabled!")

end



