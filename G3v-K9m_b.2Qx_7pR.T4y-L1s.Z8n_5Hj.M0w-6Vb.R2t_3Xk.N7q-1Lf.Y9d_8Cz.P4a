MainTab:CreateToggle({
    Name = "Hold Key",
    CurrentValue = false,
    Flag = "PulseKeyToggle",
    Callback = function(Value)
        sendNotify("Hold Key", Value and "Enabled" or "Disabled")
        _G.PulseKey = Value
        if Value then
            task.spawn(function()
                while _G.PulseKey do
                    local keyCode = getSafeKeyCode(_G.SelectedKey)
                    if keyCode then
                        VIM:SendKeyEvent(true, keyCode, false, game)
                        task.wait(_G.PulseDuration) 
                        VIM:SendKeyEvent(false, keyCode, false, game)
                    end
                    task.wait() 
                end
            end)
        end
    end,
})

MainTab:CreateDivider()

-- [[ 4. TOUCH FLING SYSTEM ]] --
MainTab:CreateToggle({
    Name = "Fling On Touch",
    CurrentValue = false,
    Flag = "TouchFlingToggle",
    Callback = function(Value)
        sendNotify("Touch Fling", Value and "Enabled" or "Disabled")
        _G.FlingEnabled = Value
        if Value then
            task.spawn(function()
                local movel = 0.1
                while _G.FlingEnabled do
                    RunService.Heartbeat:Wait()
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    
                    if hrp then
                        local vel = hrp.Velocity
                        hrp.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)
                        RunService.RenderStepped:Wait()
                        if char and hrp and hrp.Parent then hrp.Velocity = vel end
                        RunService.Stepped:Wait()
                        if char and hrp and hrp.Parent then 
                            hrp.Velocity = vel + Vector3.new(0, movel, 0)
                            movel = -movel
                        end
                    end
                end
            end)
        end
    end,
})

MainTab:CreateDivider()

-- [[ 5. TELEPORT TOOL ]] --
local TPToolName = "Teleport Tool"
MainTab:CreateToggle({
    Name = "Loop Give Teleport Tool",
    CurrentValue = false,
    Flag = "TPToolToggle",
    Callback = function(Value)
        sendNotify("Teleport Tool", Value and "Enabled" or "Disabled")
        _G.LoopTPTool = Value
        if Value then
            task.spawn(function()
                while _G.LoopTPTool do
                    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
                    local char = LocalPlayer.Character
                    if _G.LoopTPTool and backpack and char then
                        if not backpack:FindFirstChild(TPToolName) and not char:FindFirstChild(TPToolName) then
                            local TpTool = Instance.new("Tool")
                            TpTool.Name = TPToolName
                            TpTool.RequiresHandle = false
                            TpTool.Parent = backpack
                            TpTool.Activated:Connect(function()
                                local root = char:FindFirstChild("HumanoidRootPart")
                                local pos = Mouse.Hit
                                if root and pos then
                                    root.CFrame = CFrame.new(pos.X, pos.Y + 3, pos.Z, select(4, root.CFrame:components()))
                                    root.Velocity = Vector3.new(0,0,0)
                                    root.RotVelocity = Vector3.new(0,0,0)
                                end
                            end)
                        end
                    end
                    task.wait(0.5) 
                end
            end)
        else
            local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
            local char = LocalPlayer.Character
            if backpack and backpack:FindFirstChild(TPToolName) then backpack[TPToolName]:Destroy() end
            if char and char:FindFirstChild(TPToolName) then char[TPToolName]:Destroy() end
        end
    end,
})

-- [[ 6. SHOW INVENTORY LOOP ]] --
MainTab:CreateToggle({
    Name = "Force Show Native Roblox Inventory",
    CurrentValue = false,
    Flag = "ShowInvToggle",
    Callback = function(Value)
        sendNotify("Force Inventory", Value and "Enabled" or "Disabled")
        if Value then
            pcall(function() wasInventoryEnabled = StarterGui:GetCoreGuiEnabled(Enum.CoreGuiType.Backpack) end)
            connections.InventoryLoop = RunService.RenderStepped:Connect(function()
                pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, true) end)
            end)
        else
            if connections.InventoryLoop then connections.InventoryLoop:Disconnect() end
            pcall(function() StarterGui:SetCoreGuiEnabled(Enum.CoreGuiType.Backpack, wasInventoryEnabled) end)
        end
    end,
})

