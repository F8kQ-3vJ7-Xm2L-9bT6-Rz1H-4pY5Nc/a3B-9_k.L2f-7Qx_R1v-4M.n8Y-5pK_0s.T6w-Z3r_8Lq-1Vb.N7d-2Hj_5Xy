-- [[ STARTUP NOTIFICATION ]] --
pcall(function()
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "Script loaded enjoy!",
        Text = "Credits in Credits tab", 
        Duration = 5 
    })
end)

local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")
local VIM = game:GetService("VirtualInputManager")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

-- [[ FILE SAVING SYSTEM ]] --
local SaveFileName = "UtilityHub_SaveData.json"
local MySettings = {
    WalkSpeed = 16,
    Key = "F",
    Pulse = 0.1,
    Patience = 30
}

if isfile and isfile(SaveFileName) and readfile then
    local success, loadedData = pcall(function()
        return HttpService:JSONDecode(readfile(SaveFileName))
    end)
    if success and loadedData then 
        MySettings.WalkSpeed = loadedData.WalkSpeed or 16
        MySettings.Key = loadedData.Key or "F"
        MySettings.Pulse = loadedData.Pulse or 0.1
        MySettings.Patience = loadedData.Patience or 30
    end
end

local function SaveToFile()
    if writefile then
        local success, encodedData = pcall(function()
            return HttpService:JSONEncode(MySettings)
        end)
        if success then writefile(SaveFileName, encodedData) end
    end
end

-- [[ MENU CREATION ]] --
local Window = Rayfield:CreateWindow({
   Name = "Utility Hub V17",
   LoadingTitle = "Loading Scripts...",
   LoadingSubtitle = "by uz",
   ConfigurationSaving = { Enabled = false }
})

local MainTab = Window:CreateTab("Main Hacks", 4483362458)
local ExtraTab = Window:CreateTab("Extra Scripts", 4483362458)
local CreditsTab = Window:CreateTab("Credits", 4483362458)

-- [[ STATE VARIABLES ]] --
_G.TargetList = {}
_G.CurrentTargetIndex = 1
_G.Following = false
_G.SmartTargeting = false
_G.LoopSpeedValue = MySettings.WalkSpeed
_G.SelectedKey = MySettings.Key
_G.PulseDuration = MySettings.Pulse
_G.PatienceTime = MySettings.Patience
_G.FlingEnabled = false
_G.LoopTPTool = false
_G.PulseKey = false
_G.LoopServerHop = false
_G.WasDead = false 
_G.LastChar = nil
_G.SpawnTime = tick()
_G.FlingStrikes = 0

local wasInventoryEnabled = true
local connections = {} 
local HumanModCons = {} 
local targetStartTime = tick()
local lastTargetId = nil

-- [[ HELPER FUNCTIONS ]] --
local function sendNotify(title, text)
    pcall(function() StarterGui:SetCore("SendNotification", { Title = title, Text = text, Duration = 3 }) end)
end

local function getPlayerNames()
    local names = {}
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer then table.insert(names, plr.DisplayName .. " (@" .. plr.Name .. ")") end
    end
    return names
end

local function getUserIdFromFormat(formattedString)
    local username = string.match(formattedString, "@(.-)%)$")
    if username then
        local plr = Players:FindFirstChild(username)
        if plr then return plr.UserId end
    end
    return nil
end

local function getFormattedNameFromId(id)
    if not id then return "Unknown" end
    local plr = Players:GetPlayerByUserId(id)
    if plr then return plr.DisplayName .. " (@" .. plr.Name .. ")" end
    return "Offline Player"
end

local function getNextValidTargetIndex(startIndex)
    local myChar = LocalPlayer.Character
    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myRoot then return startIndex + 1 end 
    
    local checkCount = 0
    local currentIndex = startIndex + 1
    
    while checkCount < #_G.TargetList do
        if currentIndex > #_G.TargetList then currentIndex = 1 end
        
        local id = _G.TargetList[currentIndex]
        local targetPlr = Players:GetPlayerByUserId(id)
        
        if targetPlr and targetPlr.Character then
            local tRoot = targetPlr.Character:FindFirstChild("HumanoidRootPart")
            local tHum = targetPlr.Character:FindFirstChild("Humanoid")
            
            if tRoot and tHum and tHum.Health > 0 then
                local dist = (tRoot.Position - myRoot.Position).Magnitude
                if dist < 1000 then
                    return currentIndex 
                end
            end
        end
        currentIndex = currentIndex + 1
        checkCount = checkCount + 1
    end
    return startIndex + 1 
end

local function advanceTarget(reason, oldId)
    if #_G.TargetList <= 1 then 
        targetStartTime = tick() 
        return 
    end
    
    _G.CurrentTargetIndex = getNextValidTargetIndex(_G.CurrentTargetIndex)
    
    local newId = _G.TargetList[_G.CurrentTargetIndex]
    local oldName = getFormattedNameFromId(oldId)
    local newName = getFormattedNameFromId(newId)
    
    if reason == "flung" then sendNotify("Detected Flung!", oldName .. " flung! Switching to: " .. newName)
    elseif reason == "timeout" then sendNotify("Timeout", oldName .. " evaded for " .. tostring(_G.PatienceTime) .. "s. Switching to: " .. newName)
    elseif reason == "dead" then sendNotify("Target Dead", oldName .. " died. Switching to: " .. newName)
    elseif reason == "offline" then sendNotify("Target Left", oldName .. " left. Switching to: " .. newName)
    end
    
    targetStartTime = tick()
    lastTargetId = newId
end

local function getSafeKeyCode(str)
    local success, code = pcall(function() return Enum.KeyCode[str:upper()] end)
    return success and code or nil
end

-- CRASH-PROOF MAX SPEED SERVER HOP
local function performServerHop()
    local servers = {}
    -- Wrapped in pcall so it doesn't crash your script when Roblox rate-limits you
    local success, req = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100&excludeFullGames=true")
    end)
    
    if success and req then
        local body = HttpService:JSONDecode(req)
        if body and body.data then
            for _, v in next, body.data do
                if type(v) == "table" and tonumber(v.playing) and tonumber(v.maxPlayers) and v.playing < v.maxPlayers and v.id ~= game.JobId then
                    table.insert(servers, 1, v.id)
                end
            end
        end
    end
    
    if #servers > 0 then
        TeleportService:TeleportToPlaceInstance(game.PlaceId, servers[math.random(1, #servers)], LocalPlayer)
    end
end

-- [[ 1. MULTI-TARGET SYSTEM ]] --
local FollowDropdown = MainTab:CreateDropdown({
    Name = "Select Targets (Hitlist)",
    Options = getPlayerNames(),
    CurrentOption = {},
    MultipleOptions = true,
    Flag = "FollowDropdown",
    Callback = function(Options)
        _G.TargetList = {}
        for _, opt in ipairs(Options) do
            local id = getUserIdFromFormat(opt)
            if id then table.insert(_G.TargetList, id) end
        end
        _G.CurrentTargetIndex = 1
        
        if #_G.TargetList == 1 then
            sendNotify("Target Locked", "Relentlessly tracking: " .. getFormattedNameFromId(_G.TargetList[1]))
        elseif #_G.TargetList > 1 then
            sendNotify("Hitlist Updated", "Tracking " .. tostring(#_G.TargetList) .. " targets.")
        end
    end,
})

MainTab:CreateButton({
    Name = "Select All Players",
    Callback = function()
        local allNames = getPlayerNames()
        FollowDropdown:Set(allNames)
        sendNotify("Hitlist", "Selected all players in the server.")
    end,
})

MainTab:CreateButton({
    Name = "Deselect All Players",
    Callback = function()
        FollowDropdown:Set({})
        sendNotify("Hitlist", "Deselected all players.")
    end,
})

Players.PlayerAdded:Connect(function() FollowDropdown:Refresh(getPlayerNames(), true) end)
Players.PlayerRemoving:Connect(function() FollowDropdown:Refresh(getPlayerNames(), true) end)

MainTab:CreateToggle({
    Name = "Follow Target(s)",
    CurrentValue = false,
    Flag = "FollowToggle",
    Callback = function(Value)
        _G.Following = Value
        sendNotify("Follow System", Value and "Started chasing" or "Stopped chasing")
        
        if connections.Follow then connections.Follow:Disconnect() end
        if Value then
            connections.Follow = RunService.Heartbeat:Connect(function()
                if not _G.Following or #_G.TargetList == 0 then return end
                
                local myChar = LocalPlayer.Character
                local myHum = myChar and myChar:FindFirstChild("Humanoid")
                local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
                
                if myChar ~= _G.LastChar then
                    _G.LastChar = myChar
                    _G.SpawnTime = tick()
                    _G.FlingStrikes = 0
                end
                
                if not myHum or myHum.Health <= 0 then
                    if not _G.WasDead then
                        _G.WasDead = true
                        sendNotify("Targeting Paused", "You died. Waiting to respawn...")
                    end
                    return 
                elseif _G.WasDead then
                    _G.WasDead = false
                    targetStartTime = tick() 
                    sendNotify("Targeting Resumed", "You are alive. Chasing target again.")
                end
                
                if _G.CurrentTargetIndex > #_G.TargetList then _G.CurrentTargetIndex = 1 end
                
                local currentTargetId = _G.TargetList[_G.CurrentTargetIndex]
                local targetPlr = Players:GetPlayerByUserId(currentTargetId)
                
                if not targetPlr then
                    advanceTarget("offline", currentTargetId)
                    return
                end
                
                if tick() - _G.SpawnTime > 3 and myRoot and myHum and myHum.Health > 0 then
                    if myRoot.Velocity.Magnitude > 250 then
                        local nearestDist = math.huge
                        for _, p in ipairs(Players:GetPlayers()) do
                            if p ~= LocalPlayer and p.Character then
                                local pRoot = p.Character:FindFirstChild("HumanoidRootPart")
                                if pRoot then
                                    local d = (pRoot.Position - myRoot.Position).Magnitude
                                    if d < nearestDist then
                                        nearestDist = d
                                    end
                                end
                            end
                        end
                        
                        if nearestDist > 500 then
                            _G.FlingStrikes = _G.FlingStrikes + 1
                            if _G.FlingStrikes > 5 then
                                myHum.Health = 0 
                                _G.FlingStrikes = 0
                                return
                            end
                        else
                            _G.FlingStrikes = 0 
                        end
                    else
                        _G.FlingStrikes = 0 
                    end
                end
                
                local targetRoot = targetPlr.Character and targetPlr.Character:FindFirstChild("HumanoidRootPart")
                
                if targetPlr.Character and targetRoot then
                    local targetHum = targetPlr.Character:FindFirstChild("Humanoid")
                    if targetHum and targetHum.Health > 0 then
                        if myHum and myHum.Health > 0 then
                            myHum:MoveTo(targetRoot.Position)
                        end
                    else
                        advanceTarget("dead", currentTargetId)
                    end
                else
                    advanceTarget("dead", currentTargetId)
                end
            end)
        end
    end,
})

-- [[ SMART PATIENCE TIMER ]] --
MainTab:CreateInput({
    Name = "Patience Timer (Saved: " .. tostring(MySettings.Patience) .. "s)",
    PlaceholderText = "Enter Seconds (e.g. 30)",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        local num = tonumber(Text)
        if num then
            _G.PatienceTime = num
            MySettings.Patience = num
            SaveToFile()
            sendNotify("Timer Saved", "Patience timer set to " .. tostring(num) .. "s")
        end
    end,
})

MainTab:CreateToggle({
    Name = "Enable Smart Patience Timer",
    CurrentValue = false,
    Flag = "SmartTargetToggle",
    Callback = function(Value)
        _G.SmartTargeting = Value
        sendNotify("Patience Timer", Value and "Smart Targeting Active" or "Smart Targeting Disabled")
        
        if connections.SmartTarget then connections.SmartTarget:Disconnect() end
        if Value then
            connections.SmartTarget = RunService.Heartbeat:Connect(function()
                if _G.Following and _G.FlingEnabled and _G.SmartTargeting and #_G.TargetList > 0 and not _G.WasDead then
                    if _G.CurrentTargetIndex > #_G.TargetList then _G.CurrentTargetIndex = 1 end
                    local currentId = _G.TargetList[_G.CurrentTargetIndex]
                    
                    if currentId ~= lastTargetId then
                        targetStartTime = tick()
                        lastTargetId = currentId
                    end
                    
                    local targetPlr = Players:GetPlayerByUserId(currentId)
                    if not targetPlr then return end 
                    
                    local myChar = LocalPlayer.Character
                    local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
                    local targetRoot = targetPlr.Character and targetPlr.Character:FindFirstChild("HumanoidRootPart")
                    
                    if myRoot and targetRoot then
                        local dist = (targetRoot.Position - myRoot.Position).Magnitude
                        local timeElapsed = tick() - targetStartTime
                        
                        if dist > 1000 then
                            if myRoot.Velocity.Magnitude < 250 then
                                advanceTarget("flung", currentId)
                            end
                        elseif timeElapsed > _G.PatienceTime and #_G.TargetList > 1 then
                            advanceTarget("timeout", currentId)
                        end
                    end
                end
            end)
        end
    end,
})

MainTab:CreateDivider()

-- [[ 2. LOOP WALKSPEED ]] --
MainTab:CreateInput({
    Name = "WalkSpeed Value (Saved: " .. tostring(MySettings.WalkSpeed) .. ")",
    PlaceholderText = "Enter Number",
    RemoveTextAfterFocusLost = false,
    Callback = function(Text)
        local number = tonumber(Text)
        if number then 
            _G.LoopSpeedValue = number 
            MySettings.WalkSpeed = number
            SaveToFile()
            sendNotify("WalkSpeed Set", "Speed saved as " .. tostring(number))
        end
    end,
})

MainTab:CreateToggle({
    Name = "Loop WalkSpeed",
    CurrentValue = false,
    Flag = "LoopWSToggle",
    Callback = function(Value)
        sendNotify("Loop WalkSpeed", Value and "Enabled" or "Disabled")
        local function WalkSpeedChange()
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if hum then hum.WalkSpeed = _G.LoopSpeedValue end
        end

        if Value then
            WalkSpeedChange()
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if hum then HumanModCons.wsLoop = hum:GetPropertyChangedSignal("WalkSpeed"):Connect(WalkSpeedChange) end
            
            HumanModCons.wsCA = LocalPlayer.CharacterAdded:Connect(function(nChar)
                local nHum = nChar:WaitForChild("Humanoid", 5)
                if nHum then
                    WalkSpeedChange()
                    HumanModCons.wsLoop = nHum:GetPropertyChangedSignal("WalkSpeed"):Connect(WalkSpeedChange)
                end
            end)
        else
            if HumanModCons.wsLoop then HumanModCons.wsLoop:Disconnect() HumanModCons.wsLoop = nil end
            if HumanModCons.wsCA then HumanModCons.wsCA:Disconnect() HumanModCons.wsCA = nil end
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChild("Humanoid")
            if hum then hum.WalkSpeed = 16 end
        end
    end,
})

MainTab:CreateDivider()

